    {
      "id": "ja-001",
      "category": "General",
      "english": "I don't speak Japanese. Do you speak English?",
      "local": "日本語が話せません。英語を話せますか？",
      "roman": "Nihongo ga hanasemasen. Eigo o hanasemasu ka?",
      "translations": {
        "en": "I don't speak Japanese. Do you speak English?",
        "fr": "Je ne parle pas japonais. Parlez-vous anglais ?",
        "es": "No hablo japones. Habla ingles?"
      }
    },
    {
      "id": "ja-002",
      "category": "General",
      "english": "Please speak slowly.",
      "local": "ゆっくり話してください。",
      "roman": "Yukkuri hanashite kudasai.",
      "translations": {
        "en": "Please speak slowly.",
        "fr": "Parlez lentement, s'il vous plait.",
        "es": "Hable despacio, por favor."
      }
    },
